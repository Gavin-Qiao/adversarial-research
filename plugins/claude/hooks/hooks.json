{
  "description": "Rebuild principia database on session start/resume if a principia workspace exists in the current project.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/on-session-start.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
